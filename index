// STATE
let materials = JSON.parse(localStorage.getItem('sarclisa_mats') || 'null') || INITIAL_MATERIALS;
let doctors = JSON.parse(localStorage.getItem('sarclisa_docs') || 'null') || INITIAL_DOCTORS;
let sentLog = JSON.parse(localStorage.getItem('sarclisa_sent') || '{}');
let activeFilter = -1;
let delTarget = null;
let currentTab = 'medicos';

function save(){
  localStorage.setItem('sarclisa_mats', JSON.stringify(materials));
  localStorage.setItem('sarclisa_docs', JSON.stringify(doctors));
  localStorage.setItem('sarclisa_sent', JSON.stringify(sentLog));
}

function toTitle(s){return s.toLowerCase().replace(/\b\w/g,c=>c.toUpperCase())}
function formatPhone(r){return'+55'+r.replace(/\D/g,'')}
function wppUrl(phone,msg){return`https://wa.me/${formatPhone(phone)}?text=${encodeURIComponent(msg)}`}
function sentKey(dname,midx){return dname+'__'+midx}

// TAB SWITCHING
function showTab(t){
  currentTab=t;
  document.querySelectorAll('.tab').forEach((el,i)=>{
    el.classList.toggle('active',['medicos','materiais','insights'][i]===t)
  });
  document.getElementById('tab-medicos').style.display=t==='medicos'?'':'none';
  document.getElementById('tab-materiais').style.display=t==='materiais'?'block':'none';
  document.getElementById('tab-insights').style.display=t==='insights'?'block':'none';
  if(t==='materiais') renderMats();
  if(t==='insights') renderInsights();
}

// ===== CHIPS =====
function buildChips(){
  let html=`<button class="chip all ${activeFilter===-1?'active':''}" onclick="setFilter(-1)">Todos</button>`;
  materials.forEach((m,i)=>{
    html+=`<button class="chip ${activeFilter===i?'active':''}" onclick="setFilter(${i})">${m.name}</button>`;
  });
  document.getElementById('chips').innerHTML=html;
}

function setFilter(i){
  activeFilter=i;
  buildChips();
  renderDocs();
}

// ===== DOCTORS LIST =====
function renderDocs(){
  buildChips();
  const q=document.getElementById('search').value.toLowerCase().trim();
  let docs=[...doctors].map((d,i)=>({...d,_i:i})).filter(d=>!q||d.name.toLowerCase().includes(q));
  docs.sort((a,b)=>(!!b.phone-!!a.phone)||a.name.localeCompare(b.name));

  document.getElementById('stats').textContent=`${docs.length} médico${docs.length!==1?'s':''}`;

  if(!docs.length){
    document.getElementById('list').innerHTML=`<div class="empty">🔍 Nenhum médico encontrado</div>`;
    return;
  }

  const mats=activeFilter>=0?[{m:materials[activeFilter],idx:activeFilter}]:materials.map((m,i)=>({m,idx:i}));

  document.getElementById('list').innerHTML=docs.map(doc=>{
    const di=doc._i;
    const rows=mats.map(({m,idx})=>{
      const sk=sentKey(doc.name,idx);
      const sent=sentLog[sk];
      const badge=sent?`<span class="sent-badge">✓ Enviado</span>`:'';
      const btn=doc.phone
        ?`<a class="wpp-btn" href="${wppUrl(doc.phone,m.msg)}" onclick="markSent('${doc.name.replace(/'/g,"\\'")}',${idx})" target="_blank" rel="noopener">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Enviar
          </a>`
        :`<span class="no-phone">Sem número</span>`;
      return`<div class="mat-row"><div class="mat-label">${m.name}${badge}</div>${btn}</div>`;
    }).join('');

    return`<div class="card" id="dc-${di}">
      <div class="card-hd">
        <div class="card-hd-info" onclick="toggleCard(${di})">
          <div class="doc-name">${toTitle(doc.name)}</div>
          <div class="doc-phone">${doc.phone?'📱 '+doc.phone:'⚠️ Sem WhatsApp'}</div>
        </div>
        <div class="card-actions">
          <button class="icon-btn" onclick="openDocModal(${di})">✏️</button>
          <button class="icon-btn del" onclick="askDel('doc',${di})">🗑️</button>
        </div>
        <div class="chevron" onclick="toggleCard(${di})">▼</div>
      </div>
      <div class="card-body">${rows}</div>
    </div>`;
  }).join('');
}

function toggleCard(i){document.getElementById('dc-'+i).classList.toggle('open')}

function markSent(name,midx){
  const k=sentKey(name,midx);
  sentLog[k]=new Date().toISOString();
  save();
  setTimeout(renderDocs,500);
}

// ===== DOC MODAL =====
function openDocModal(idx){
  document.getElementById('doc-idx').value=idx===undefined?'':idx;
  if(idx!==undefined){
    const d=doctors[idx];
    document.getElementById('doc-name-inp').value=d.name;
    document.getElementById('doc-phone-inp').value=d.phone;
  } else {
    document.getElementById('doc-name-inp').value='';
    document.getElementById('doc-phone-inp').value='';
  }
  document.getElementById('doc-modal').classList.add('open');
  setTimeout(()=>document.getElementById('doc-name-inp').focus(),100);
}
function closeDocModal(){document.getElementById('doc-modal').classList.remove('open')}
function saveDoc(){
  const name=document.getElementById('doc-name-inp').value.trim().toUpperCase();
  const phone=document.getElementById('doc-phone-inp').value.trim();
  if(!name){alert('Informe o nome.');return;}
  const idx=document.getElementById('doc-idx').value;
  if(idx===''){
    doctors.push({name,phone,marks:materials.map(()=>false)});
  } else {
    doctors[+idx].name=name;
    doctors[+idx].phone=phone;
  }
  save(); closeDocModal(); renderDocs();
}

// ===== MATERIALS =====
function renderMats(){
  document.getElementById('mat-list').innerHTML=materials.map((m,i)=>`
    <div class="mat-card">
      <div class="mat-card-title">${m.name}</div>
      <div class="mat-card-preview">${m.msg}</div>
      <div class="mat-card-actions">
        <button class="icon-btn" onclick="openMatModal(${i})">✏️ Editar</button>
        <button class="icon-btn del" onclick="askDel('mat',${i})">🗑️ Excluir</button>
      </div>
    </div>`).join('');
}

function openMatModal(idx){
  document.getElementById('mat-idx').value=idx===undefined?'':idx;
  if(idx!==undefined){
    document.getElementById('mat-name-inp').value=materials[idx].name;
    document.getElementById('mat-msg-inp').value=materials[idx].msg;
  } else {
    document.getElementById('mat-name-inp').value='';
    document.getElementById('mat-msg-inp').value='';
  }
  document.getElementById('mat-modal').classList.add('open');
}
function closeMatModal(){document.getElementById('mat-modal').classList.remove('open')}
function saveMat(){
  const name=document.getElementById('mat-name-inp').value.trim();
  const msg=document.getElementById('mat-msg-inp').value.trim();
  if(!name||!msg){alert('Preencha nome e mensagem.');return;}
  const idx=document.getElementById('mat-idx').value;
  if(idx===''){
    materials.push({name,msg});
    doctors.forEach(d=>d.marks.push(false));
  } else {
    materials[+idx].name=name;
    materials[+idx].msg=msg;
  }
  save(); closeMatModal(); renderMats(); buildChips();
}

// ===== DELETE =====
function askDel(type,idx){
  delTarget={type,idx};
  const label=type==='doc'?toTitle(doctors[idx].name):materials[idx].name;
  document.getElementById('del-msg').textContent=`Excluir "${label}"? Esta ação não pode ser desfeita.`;
  document.getElementById('del-modal').classList.add('open');
}
function closeDelModal(){document.getElementById('del-modal').classList.remove('open')}
function confirmDel(){
  if(!delTarget)return;
  if(delTarget.type==='doc'){
    doctors.splice(delTarget.idx,1);
    save(); closeDelModal(); renderDocs();
  } else {
    const i=delTarget.idx;
    materials.splice(i,1);
    doctors.forEach(d=>d.marks.splice(i,1));
    save(); closeDelModal(); renderMats(); buildChips();
  }
}

// ===== INSIGHTS =====
function renderInsights(){
  const total=doctors.length;
  const withPhone=doctors.filter(d=>d.phone).length;
  const noPhone=total-withPhone;

  // sent stats per material
  const sentPerMat=materials.map((m,i)=>{
    const count=doctors.filter(d=>sentLog[sentKey(d.name,i)]).length;
    return{name:m.name,count,pct:total?Math.round(count/total*100):0};
  }).sort((a,b)=>b.count-a.count);

  // doctors with most materials sent
  const docsSent=doctors.map(d=>{
    const c=materials.filter((_,i)=>sentLog[sentKey(d.name,i)]).length;
    return{name:d.name,c};
  }).sort((a,b)=>b.c-a.c).slice(0,5);

  const totalSent=Object.keys(sentLog).length;
  const coverage=total*materials.length?Math.round(totalSent/(total*materials.length)*100):0;

  document.getElementById('insights-content').innerHTML=`
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:10px">
      <div style="background:#f3f0ff;border-radius:12px;padding:12px;text-align:center">
        <div style="font-size:11px;color:#7C3AED;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Médicos</div>
        <div style="font-size:28px;font-weight:700;color:#7C3AED">${total}</div>
      </div>
      <div style="background:#e8f5e9;border-radius:12px;padding:12px;text-align:center">
        <div style="font-size:11px;color:#2e7d32;font-weight:600;text-transform:uppercase;letter-spacing:.5px">Enviados</div>
        <div style="font-size:28px;font-weight:700;color:#2e7d32">${totalSent}</div>
      </div>
    </div>

    <div class="insight-card">
      <h3>📊 Cobertura por material</h3>
      ${sentPerMat.map(m=>`
        <div class="insight-row">
          <span>${m.name}</span>
          <span class="pill ${m.pct>=50?'green':m.pct>=20?'orange':'red'}">${m.count} (${m.pct}%)</span>
        </div>`).join('')}
    </div>

    <div class="insight-card">
      <h3>📱 Cobertura de contatos</h3>
      <div class="insight-row"><span>Com WhatsApp</span><span class="pill green">${withPhone}</span></div>
      <div class="insight-row"><span>Sem número</span><span class="pill ${noPhone>0?'red':'green'}">${noPhone}</span></div>
      <div class="insight-row"><span>Cobertura total</span><span class="pill blue">${coverage}%</span></div>
    </div>

    <div class="insight-card">
      <h3>🏆 Médicos mais impactados</h3>
      ${docsSent.map(d=>`
        <div class="insight-row">
          <span>${toTitle(d.name)}</span>
          <span class="pill blue">${d.c} mat.</span>
        </div>`).join('')}
      ${docsSent.every(d=>d.c===0)?'<div style="font-size:13px;color:#8e8e93;padding:8px 0">Nenhum envio registrado ainda.</div>':''}
    </div>

    <div style="font-size:15px;font-weight:700;margin:14px 0 8px">💡 Sugestões de melhoria</div>

    <div class="tip-box"><div class="tip-title">🖼️ Imagem no WhatsApp</div>O WhatsApp via link (wa.me) não permite pré-carregar imagens por limitação da plataforma. Solução: salve a imagem na galeria do celular antes de enviar → após clicar "Enviar" e o WhatsApp abrir, pressione o clipe 📎 e selecione a imagem. Outra alternativa: cole o link da imagem direto na mensagem pré-escrita.</div>

    <div class="tip-box"><div class="tip-title">📅 Agendamento de envios</div>Adicione um campo "data de envio planejado" por médico+material, e filtre quem deve receber hoje. Isso transforma o app em um plano de comunicação completo.</div>

    <div class="tip-box"><div class="tip-title">🏷️ Potencial do médico (A/B/C)</div>Integre o score de prioridade do painel (A/B/C) para ordenar médicos por impacto. Primeiro os de alta prioridade que ainda não receberam todos os materiais.</div>

    <div class="tip-box"><div class="tip-title">📊 Histórico de interações</div>Registre a resposta do médico após o envio (ex: "Interessado", "Pediu mais info", "Sem retorno"). Isso cria um CRM básico de relacionamento.</div>

    <div class="tip-box"><div class="tip-title">🔔 Lembretes de follow-up</div>Após marcar como enviado, agende um lembrete de 7 dias para follow-up. No iOS, um link <code>x-apple-reminderkit://</code> pode abrir o app Lembretes direto.</div>

    <div class="tip-box"><div class="tip-title">☁️ Sincronização em nuvem</div>Hoje os dados ficam no navegador (localStorage). Para compartilhar com a equipe ou ter backup, integrar com Google Sheets via Apps Script ou Airtable seria o próximo passo natural.</div>

    <div class="tip-box"><div class="tip-title">🎯 Segmentação por especialidade</div>Adicione tag de especialidade aos médicos (Hematologia, Farmácia) e filtre materiais sugeridos por perfil — ex: materiais de posologia para farmacêuticos.</div>
  `;
}

// INIT
renderDocs();
