  DATA.materials.forEach((m, i) => {
    html += `<button class="chip" id="chip-${i}" onclick="setFilter(${i})">${m.name}</button>`;
  });
  el.innerHTML = html;
}

function setFilter(idx) {
  activeFilter = idx;
  document.querySelectorAll('.chip').forEach((c, i) => {
    c.classList.remove('active');
    if (i === 0 && idx === -1) c.classList.add('active');
    if (i === idx + 1) c.classList.add('active');
  });
  render();
}

