<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>Sarclisa – Materiais</title>
<style>
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f2f2f7;color:#1c1c1e;min-height:100vh;padding-bottom:80px}

/* TABS */
.tab-bar{display:flex;background:#fff;border-bottom:1px solid #e5e5ea;position:sticky;top:0;z-index:200}
.tab{flex:1;padding:14px 4px 12px;text-align:center;font-size:12px;font-weight:600;color:#8e8e93;border:none;background:none;cursor:pointer;border-bottom:2px solid transparent;transition:all .15s}
.tab.active{color:#7C3AED;border-bottom-color:#7C3AED}

/* HEADER */
.page-header{background:#7C3AED;color:#fff;padding:14px 14px 10px;display:flex;align-items:center;justify-content:space-between}
.page-header h1{font-size:17px;font-weight:700}
.page-header p{font-size:11px;opacity:.8;margin-top:1px}
.header-btn{background:rgba(255,255,255,.2);border:none;color:#fff;border-radius:20px;padding:6px 12px;font-size:12px;font-weight:600;cursor:pointer}

/* SEARCH */
.search-wrap{padding:10px 12px;background:#f2f2f7;position:sticky;top:45px;z-index:99}
.search-wrap input{width:100%;padding:9px 14px;border-radius:12px;border:none;background:#fff;font-size:15px;outline:none;box-shadow:0 1px 3px rgba(0,0,0,.1)}

/* CHIPS */
.chips{padding:0 12px 8px;display:flex;gap:6px;overflow-x:auto;scrollbar-width:none}
.chips::-webkit-scrollbar{display:none}
.chip{white-space:nowrap;padding:5px 12px;border-radius:20px;font-size:12px;font-weight:600;border:none;cursor:pointer;background:#fff;color:#7C3AED;box-shadow:0 1px 3px rgba(0,0,0,.1)}
.chip.active{background:#7C3AED;color:#fff}
.chip.all{background:#e5e7eb;color:#374151}
.chip.all.active{background:#374151;color:#fff}

.stats-row{padding:0 12px 6px;font-size:12px;color:#8e8e93}

/* CARDS */
.list{padding:0 12px;display:flex;flex-direction:column;gap:8px}
.card{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.08)}
.card-hd{padding:12px 14px;display:flex;align-items:center;gap:10px}
.card-hd-info{flex:1;cursor:pointer}
.doc-name{font-size:14px;font-weight:600;color:#1c1c1e}
.doc-phone{font-size:11px;color:#8e8e93;margin-top:1px}
.chevron{font-size:10px;color:#c7c7cc;transition:transform .2s;cursor:pointer;padding:4px}
.card.open .chevron{transform:rotate(180deg)}
.card-actions{display:flex;gap:6px}
.icon-btn{background:none;border:1px solid #e5e5ea;border-radius:8px;padding:5px 8px;font-size:13px;cursor:pointer;color:#3c3c43}
.icon-btn.del{border-color:#ffcdd2;color:#e53935}

.card-body{display:none;border-top:1px solid #f2f2f7}
.card.open .card-body{display:block}

.mat-row{display:flex;align-items:center;gap:8px;padding:10px 14px;border-bottom:1px solid #f9f9f9}
.mat-row:last-child{border-bottom:none}
.mat-label{font-size:13px;color:#3c3c43;flex:1;line-height:1.3}
.sent-badge{display:inline-block;font-size:10px;background:#d1fae5;color:#065f46;border-radius:6px;padding:1px 5px;margin-left:5px;font-weight:600}
.wpp-btn{display:flex;align-items:center;gap:5px;background:#25D366;color:#fff;border:none;border-radius:10px;padding:8px 12px;font-size:13px;font-weight:600;cursor:pointer;white-space:nowrap;text-decoration:none;flex-shrink:0}
.wpp-btn:active{opacity:.75}
.no-phone{font-size:11px;color:#e53935;background:#fff1f0;padding:5px 8px;border-radius:8px;flex-shrink:0}

/* MODALS */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:500;align-items:flex-end;justify-content:center}
.overlay.open{display:flex}
.modal{background:#fff;border-radius:20px 20px 0 0;width:100%;max-width:500px;padding:20px 20px 40px;max-height:90vh;overflow-y:auto}
.modal h2{font-size:17px;font-weight:700;margin-bottom:16px;display:flex;justify-content:space-between;align-items:center}
.modal h2 button{background:none;border:none;font-size:20px;color:#8e8e93;cursor:pointer;line-height:1}
.field{margin-bottom:14px}
.field label{font-size:12px;font-weight:600;color:#8e8e93;display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:.5px}
.field input,.field textarea{width:100%;padding:10px 12px;border-radius:10px;border:1px solid #e5e5ea;font-size:15px;font-family:inherit;outline:none;background:#f9f9f9}
.field input:focus,.field textarea:focus{border-color:#7C3AED;background:#fff}
.field textarea{resize:vertical;min-height:90px}
.btn-row{display:flex;gap:10px;margin-top:6px}
.btn-primary{flex:1;background:#7C3AED;color:#fff;border:none;border-radius:12px;padding:13px;font-size:15px;font-weight:700;cursor:pointer}
.btn-danger{flex:1;background:#e53935;color:#fff;border:none;border-radius:12px;padding:13px;font-size:15px;font-weight:700;cursor:pointer}
.btn-ghost{flex:1;background:#f2f2f7;color:#3c3c43;border:none;border-radius:12px;padding:13px;font-size:15px;font-weight:600;cursor:pointer}

/* MATERIAIS TAB */
.mat-card{background:#fff;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.08);padding:14px;margin-bottom:8px}
.mat-card-title{font-size:14px;font-weight:600;margin-bottom:4px}
.mat-card-preview{font-size:12px;color:#8e8e93;line-height:1.4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100%}
.mat-card-actions{display:flex;gap:8px;margin-top:10px}

/* INSIGHTS TAB */
.insight-card{background:#fff;border-radius:14px;box-shadow:0 1px 3px rgba(0,0,0,.08);padding:14px;margin-bottom:8px}
.insight-card h3{font-size:14px;font-weight:700;margin-bottom:8px}
.insight-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid #f2f2f7;font-size:13px}
.insight-row:last-child{border-bottom:none}
.pill{padding:2px 8px;border-radius:20px;font-size:11px;font-weight:700}
.pill.green{background:#d1fae5;color:#065f46}
.pill.orange{background:#fff3e0;color:#e65100}
.pill.red{background:#ffebee;color:#b71c1c}
.pill.blue{background:#e3f2fd;color:#0d47a1}
.tip-box{background:#f3f0ff;border-left:3px solid #7C3AED;border-radius:0 10px 10px 0;padding:10px 12px;margin-bottom:8px;font-size:13px;color:#4a2d9c;line-height:1.5}
.tip-title{font-weight:700;font-size:12px;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px}

.empty{text-align:center;padding:50px 20px;color:#8e8e93}
.fab{position:fixed;bottom:24px;right:16px;background:#7C3AED;color:#fff;border:none;border-radius:50%;width:52px;height:52px;font-size:24px;cursor:pointer;box-shadow:0 4px 12px rgba(124,58,237,.4);z-index:300;display:flex;align-items:center;justify-content:center}

/* WHATSAPP IMAGE NOTE */
.wpp-note{background:#e8f5e9;border-radius:10px;padding:10px 12px;margin:0 12px 10px;font-size:12px;color:#2e7d32;line-height:1.5}
</style>
</head>
<body>

<div class="tab-bar">
  <button class="tab active" onclick="showTab('medicos')">👨‍⚕️ Médicos</button>
  <button class="tab" onclick="showTab('materiais')">📄 Materiais</button>
  <button class="tab" onclick="showTab('insights')">📊 Insights</button>
</div>

<!-- ===== MÉDICOS TAB ===== -->
<div id="tab-medicos">
  <div class="page-header">
    <div><h1>Sarclisa – WhatsApp</h1><p id="hdr-subtitle">Toque no médico para enviar materiais</p></div>
    <button class="header-btn" onclick="openDocModal()">+ Médico</button>
  </div>
  <div class="search-wrap"><input id="search" type="search" placeholder="🔍 Buscar médico..." oninput="renderDocs()" autocomplete="off" autocorrect="off" spellcheck="false"></div>
  <div class="chips" id="chips"></div>
  <div class="wpp-note">💡 <b>Imagem no WhatsApp:</b> Após clicar em "Enviar", o WhatsApp abrirá com o texto pré-preenchido. Para anexar imagem: pressione e segure o campo de texto → cole imagem ou use o clipe 📎. O iOS não permite pré-anexar imagens via link — é um limite do WhatsApp.</div>
  <div class="stats-row" id="stats"></div>
  <div class="list" id="list"></div>
  <button class="fab" onclick="openDocModal()">+</button>
</div>

<!-- ===== MATERIAIS TAB ===== -->
<div id="tab-materiais" style="display:none;padding:12px">
  <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px">
    <span style="font-size:17px;font-weight:700">Materiais WhatsApp</span>
    <button class="header-btn" style="background:#7C3AED;color:#fff" onclick="openMatModal()">+ Material</button>
  </div>
  <div id="mat-list"></div>
</div>

<!-- ===== INSIGHTS TAB ===== -->
<div id="tab-insights" style="display:none;padding:12px">
  <div style="font-size:17px;font-weight:700;margin-bottom:12px">Insights & Melhorias</div>
  <div id="insights-content"></div>
</div>

<!-- MODAL MÉDICO -->
<div class="overlay" id="doc-modal">
  <div class="modal">
    <h2>Médico <button onclick="closeDocModal()">×</button></h2>
    <input type="hidden" id="doc-idx">
    <div class="field"><label>Nome completo</label><input id="doc-name-inp" placeholder="Ex: João Silva Santos" autocomplete="off"></div>
    <div class="field"><label>WhatsApp (ex: 19-99999-9999)</label><input id="doc-phone-inp" placeholder="DDD-NNNNN-NNNN" type="tel"></div>
    <div class="btn-row">
      <button class="btn-ghost" onclick="closeDocModal()">Cancelar</button>
      <button class="btn-primary" onclick="saveDoc()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL MATERIAL -->
<div class="overlay" id="mat-modal">
  <div class="modal">
    <h2>Material <button onclick="closeMatModal()">×</button></h2>
    <input type="hidden" id="mat-idx">
    <div class="field"><label>Nome do material</label><input id="mat-name-inp" placeholder="Ex: IMROZ – Eficácia"></div>
    <div class="field"><label>Mensagem WhatsApp</label><textarea id="mat-msg-inp" placeholder="Olá! ..."></textarea></div>
    <div class="btn-row">
      <button class="btn-ghost" onclick="closeMatModal()">Cancelar</button>
      <button class="btn-primary" onclick="saveMat()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL CONFIRMAR DELETE -->
<div class="overlay" id="del-modal">
  <div class="modal">
    <h2>Confirmar exclusão <button onclick="closeDelModal()">×</button></h2>
    <p style="font-size:14px;color:#3c3c43;margin-bottom:20px" id="del-msg">Tem certeza?</p>
    <div class="btn-row">
      <button class="btn-ghost" onclick="closeDelModal()">Cancelar</button>
      <button class="btn-danger" onclick="confirmDel()">Excluir</button>
    </div>
  </div>
</div>

