var mats = MATS;
var docs = DOCS;
var sent = {};
var activeMat = -1;
var potFilter = {A:true, B:true, C:true};
var editDocIdx = -1;
var editMatIdx = -1;
var delType = '';
var delIdx = -1;

try { var s = localStorage.getItem('sc_sent'); if (s) sent = JSON.parse(s); } catch(e) {}
try { var dm = localStorage.getItem('sc_mats'); if (dm) mats = JSON.parse(dm); } catch(e) {}
try { var dd = localStorage.getItem('sc_docs'); if (dd) docs = JSON.parse(dd); } catch(e) {}

function persist() {
  try { localStorage.setItem('sc_sent', JSON.stringify(sent)); } catch(e) {}
  try { localStorage.setItem('sc_mats', JSON.stringify(mats)); } catch(e) {}
  try { localStorage.setItem('sc_docs', JSON.stringify(docs)); } catch(e) {}
}

// ─── HELPERS ─────────────────────────────────────────────────────────────────
function tc(s) {
  if (!s) return '';
  return s.toLowerCase().replace(/\b(\w)/g, function(c){ return c.toUpperCase(); });
}
function esc(s) {
  if (!s) return '';
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#39;');
}
function wurl(phone, msg) {
  var num = '+55' + phone.replace(/\D/g,'');
  return 'https://wa.me/' + num + '?text=' + encodeURIComponent(msg);
}
function sk(name, i) { return name + '__' + i; }

// ─── TABS ─────────────────────────────────────────────────────────────────────
function showTab(n) {
  for (var i = 0; i < 3; i++) {
    document.getElementById('tab' + i).classList.toggle('active', i === n);
    document.getElementById('page' + i).classList.toggle('active', i === n);
  }
  if (n === 1) renderMats();
  if (n === 2) renderInsights();
}

// ─── CHIPS ───────────────────────────────────────────────────────────────────
function buildChips() {
  var html = '<button class="fchip' + (activeMat === -1 ? ' active' : '') + '" onclick="setMat(-1)">Todos</button>';
  for (var i = 0; i < mats.length; i++) {
    html += '<button class="fchip' + (activeMat === i ? ' active' : '') + '" onclick="setMat(' + i + ')">' + esc(mats[i].name) + '</button>';
  }
  document.getElementById('filterRow').innerHTML = html;
}
function setMat(i) { activeMat = i; buildChips(); renderDocs(); }

function togglePot(p) {
  potFilter[p] = !potFilter[p];
  document.getElementById('pot' + p).classList.toggle('dim', !potFilter[p]);
  renderDocs();
}

// ─── DOCS ─────────────────────────────────────────────────────────────────────
function renderDocs() {
  buildChips();
  var q = document.getElementById('searchInput').value.toLowerCase().trim();
  var filtered = [];
  for (var i = 0; i < docs.length; i++) {
    var d = docs[i];
    if (!potFilter[d.pot]) continue;
    if (q) {
      var hay = (d.name + ' ' + (d.city||'') + ' ' + (d.conta||'')).toLowerCase();
      if (hay.indexOf(q) === -1) continue;
    }
    filtered.push({d: d, i: i});
  }
  filtered.sort(function(a, b) {
    var po = {A:0, B:1, C:2};
    if (po[a.d.pot] !== po[b.d.pot]) return po[a.d.pot] - po[b.d.pot];
    if (!!b.d.phone !== !!a.d.phone) return a.d.phone ? -1 : 1;
    return a.d.name.localeCompare(b.d.name);
  });

  document.getElementById('statsLine').textContent = filtered.length + ' médico' + (filtered.length !== 1 ? 's' : '');

  if (!filtered.length) {
    document.getElementById('docList').innerHTML = '<div class="empty">Nenhum médico encontrado.</div>';
    return;
  }

  var matList = activeMat >= 0 ? [{m: mats[activeMat], mi: activeMat}] : mats.map(function(m, i){ return {m:m, mi:i}; });

  var html = '';
  for (var f = 0; f < filtered.length; f++) {
    var d = filtered[f].d;
    var di = filtered[f].i;
    var sentCount = 0;
    for (var mi = 0; mi < mats.length; mi++) { if (sent[sk(d.name, mi)]) sentCount++; }

    var rows = '';
    for (var r = 0; r < matList.length; r++) {
      var m = matList[r].m;
      var midx = matList[r].mi;
      var wasSent = sent[sk(d.name, midx)];
      var badge = wasSent ? '<span class="sent-tag">✓ Enviado</span>' : '';
      var btn = d.phone
        ? '<a class="wpp-link" href="' + wurl(d.phone, m.msg) + '" onclick="markSent(\'' + di + '\',\'' + midx + '\')" target="_blank" rel="noopener"><svg width="13" height="13" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg> Enviar</a>'
        : '<span class="no-wpp">Sem número</span>';
      rows += '<div class="mat-item"><div class="mat-name">' + esc(m.name) + badge + '</div>' + btn + '</div>';
    }

    var detail = '<div class="doc-info"><span><b>CRM:</b> ' + esc(d.crm||'—') + '</span><span><b>Cidade:</b> ' + esc(tc(d.city||'—')) + '</span><span><b>Conta:</b> ' + esc(d.conta||'—') + '</span><span><b>Enviados:</b> ' + sentCount + '/' + mats.length + '</span></div>';

    html += '<div class="doc-card" id="dc' + di + '">' +
      '<div class="doc-head">' +
        '<div class="doc-main" onclick="toggleDoc(' + di + ')">' +
          '<div class="doc-name"><span class="badge b' + d.pot + '">' + d.pot + '</span>' + esc(tc(d.name)) + '</div>' +
          '<div class="doc-sub">' + (d.phone ? '📱 ' + esc(d.phone) : '⚠️ Sem WhatsApp') + ' · ' + esc(tc(d.city||'')) + ' · ' + esc(d.conta||'') + '</div>' +
        '</div>' +
        '<div class="doc-btns">' +
          '<button class="edit-btn" onclick="openDocModal(' + di + ')">✏️</button>' +
          '<button class="del-btn" onclick="askDel(\'doc\',' + di + ')">🗑️</button>' +
        '</div>' +
        '<button class="chevron-btn" onclick="toggleDoc(' + di + ')">▼</button>' +
      '</div>' +
      '<div class="doc-body">' + detail + rows + '</div>' +
    '</div>';
  }
  document.getElementById('docList').innerHTML = html;
}

function toggleDoc(i) {
  var el = document.getElementById('dc' + i);
  if (el) el.classList.toggle('open');
}

function markSent(di, mi) {
  var dname = docs[parseInt(di)].name;
  sent[sk(dname, parseInt(mi))] = new Date().toISOString();
  persist();
  setTimeout(renderDocs, 300);
}

// ─── DOC MODAL ───────────────────────────────────────────────────────────────
function openDocModal(idx) {
  editDocIdx = idx;
  document.getElementById('docModalTitle').childNodes[0].textContent = idx === -1 ? 'Novo Médico ' : 'Editar Médico ';
  if (idx >= 0) {
    var d = docs[idx];
    document.getElementById('iName').value = d.name || '';
    document.getElementById('iCrm').value = d.crm || '';
    document.getElementById('iPot').value = d.pot || 'C';
    document.getElementById('iPhone').value = d.phone || '';
    document.getElementById('iCity').value = d.city || '';
    document.getElementById('iEsp').value = d.esp || 'Hematologia (BR)';
    document.getElementById('iConta').value = d.conta || '';
  } else {
    document.getElementById('iName').value = '';
    document.getElementById('iCrm').value = '';
    document.getElementById('iPot').value = 'C';
    document.getElementById('iPhone').value = '';
    document.getElementById('iCity').value = '';
    document.getElementById('iEsp').value = 'Hematologia (BR)';
    document.getElementById('iConta').value = '';
  }
  document.getElementById('docOverlay').classList.add('active');
}
function closeDocModal() { document.getElementById('docOverlay').classList.remove('active'); }
function saveDoc() {
  var name = document.getElementById('iName').value.trim().toUpperCase();
  if (!name) { alert('Informe o nome.'); return; }
  var d = {
    name: name,
    crm: document.getElementById('iCrm').value.trim(),
    pot: document.getElementById('iPot').value,
    phone: document.getElementById('iPhone').value.trim(),
    city: document.getElementById('iCity').value.trim().toUpperCase(),
    esp: document.getElementById('iEsp').value,
    conta: document.getElementById('iConta').value.trim()
  };
  if (editDocIdx === -1) { docs.push(d); }
  else { docs[editDocIdx] = d; }
  persist(); closeDocModal(); renderDocs();
}

// ─── MAT MODAL ───────────────────────────────────────────────────────────────
function openMatModal(idx) {
  editMatIdx = idx;
  document.getElementById('matModalTitle').childNodes[0].textContent = idx === -1 ? 'Novo Material ' : 'Editar Material ';
  document.getElementById('mName').value = idx >= 0 ? mats[idx].name : '';
  document.getElementById('mMsg').value = idx >= 0 ? mats[idx].msg : '';
  document.getElementById('matOverlay').classList.add('active');
}
function closeMatModal() { document.getElementById('matOverlay').classList.remove('active'); }
function saveMat() {
  var name = document.getElementById('mName').value.trim();
  var msg = document.getElementById('mMsg').value.trim();
  if (!name || !msg) { alert('Preencha nome e mensagem.'); return; }
  if (editMatIdx === -1) { mats.push({name:name, msg:msg}); }
  else { mats[editMatIdx] = {name:name, msg:msg}; }
  persist(); closeMatModal(); renderMats(); buildChips();
}

// ─── DELETE ───────────────────────────────────────────────────────────────────
function askDel(type, idx) {
  delType = type; delIdx = idx;
  var label = type === 'doc' ? tc(docs[idx].name) : mats[idx].name;
  document.getElementById('delMsg').textContent = 'Deseja excluir "' + label + '"? Esta ação não pode ser desfeita.';
  document.getElementById('delOverlay').classList.add('active');
}
function closeDelModal() { document.getElementById('delOverlay').classList.remove('active'); }
function confirmDel() {
  if (delType === 'doc') { docs.splice(delIdx, 1); persist(); closeDelModal(); renderDocs(); }
  else { mats.splice(delIdx, 1); if (activeMat >= mats.length) activeMat = -1; persist(); closeDelModal(); renderMats(); buildChips(); }
}

// ─── MATERIAIS PAGE ───────────────────────────────────────────────────────────
function renderMats() {
  var html = '';
  for (var i = 0; i < mats.length; i++) {
    var m = mats[i];
    html += '<div class="mcard"><div class="mcard-title">' + esc(m.name) + '</div><div class="mcard-preview">' + esc(m.msg) + '</div><div class="mcard-actions"><button class="edit-btn" onclick="openMatModal(' + i + ')">✏️ Editar</button><button class="del-btn" onclick="askDel(\'mat\',' + i + ')">🗑️ Excluir</button></div></div>';
  }
  document.getElementById('matList').innerHTML = html;
}

// ─── INSIGHTS ────────────────────────────────────────────────────────────────
function renderInsights() {
  var total = docs.length;
  var withPhone = 0;
  for (var i = 0; i < docs.length; i++) { if (docs[i].phone) withPhone++; }
  var totalSent = Object.keys(sent).length;
  var coverage = total * mats.length ? Math.round(totalSent / (total * mats.length) * 100) : 0;
  var potA = docs.filter(function(d){ return d.pot==='A'; }).length;
  var potACov = 0;
  if (potA > 0 && mats.length > 0) {
    var potASent = 0;
    docs.filter(function(d){ return d.pot==='A'; }).forEach(function(d){
      for (var i = 0; i < mats.length; i++) { if (sent[sk(d.name,i)]) potASent++; }
    });
    potACov = Math.round(potASent / (potA * mats.length) * 100);
  }

  var byMat = mats.map(function(m, i) {
    var c = 0; docs.forEach(function(d){ if (sent[sk(d.name,i)]) c++; });
    return {name: m.name, c: c, pct: total ? Math.round(c/total*100) : 0};
  }).sort(function(a,b){ return b.c-a.c; });

  var byCity = {};
  docs.forEach(function(d){ if (d.city) byCity[d.city] = (byCity[d.city]||0)+1; });
  var topCities = Object.keys(byCity).map(function(k){ return [k, byCity[k]]; }).sort(function(a,b){ return b[1]-a[1]; }).slice(0,6);

  var topDocs = docs.map(function(d){
    var c = 0; for(var i=0;i<mats.length;i++){if(sent[sk(d.name,i)])c++;} return {name:d.name,pot:d.pot,c:c};
  }).filter(function(d){ return d.c>0; }).sort(function(a,b){ return b.c-a.c; }).slice(0,5);

  var byMatsHtml = byMat.map(function(m){
    var cls = m.pct>=50?'pg':m.pct>=20?'po':'pr';
    return '<div class="ins-row"><span>'+esc(m.name)+'</span><div style="display:flex;align-items:center;gap:6px;flex-shrink:0"><div class="prog"><div class="prog-fill" style="width:'+m.pct+'%"></div></div><span class="pill '+cls+'">'+m.c+' ('+m.pct+'%)</span></div></div>';
  }).join('');

  var cityHtml = topCities.map(function(c){ return '<div class="ins-row"><span>'+esc(tc(c[0]))+'</span><span class="pill pb">'+c[1]+' médicos</span></div>'; }).join('');

  var topDocsHtml = topDocs.length ? '<div class="ins-card"><h3>🏆 Mais impactados</h3>' + topDocs.map(function(d){ return '<div class="ins-row"><span><span class="badge b'+d.pot+'">'+d.pot+'</span>'+esc(tc(d.name))+'</span><span class="pill pg">'+d.c+'/'+mats.length+'</span></div>'; }).join('') + '</div>' : '';

  document.getElementById('insContent').innerHTML =
    '<div class="metric-grid">' +
      '<div class="metric m1"><span class="mlabel">Total</span><span class="mval">'+total+'</span></div>' +
      '<div class="metric m2"><span class="mlabel">Enviados</span><span class="mval">'+totalSent+'</span></div>' +
      '<div class="metric m3"><span class="mlabel">Cobertura</span><span class="mval">'+coverage+'%</span></div>' +
      '<div class="metric m4"><span class="mlabel">Potencial A</span><span class="mval">'+potACov+'%</span></div>' +
    '</div>' +
    '<div class="ins-card"><h3>📊 Cobertura por material</h3>' + byMatsHtml + '</div>' +
    '<div class="ins-card"><h3>🗺️ Top cidades</h3>' + cityHtml + '</div>' +
    '<div class="ins-card"><h3>📱 Contatos</h3>' +
      '<div class="ins-row"><span>Com WhatsApp</span><span class="pill pg">'+withPhone+'</span></div>' +
      '<div class="ins-row"><span>Sem número ⚠️</span><span class="pill '+(total-withPhone>0?'pr':'pg')+'">'+(total-withPhone)+'</span></div>' +
    '</div>' +
    topDocsHtml +
    '<div class="section-title">💡 Como potencializar</div>' +
    '<div class="tip"><b>🎯 Comece pelo Potencial A</b>São '+potA+' médicos. Filtrar só o Pot. A e garantir 100% de cobertura nesse grupo gera o maior retorno por envio.</div>' +
    '<div class="tip"><b>🖼️ Imagem no WhatsApp</b>O link wa.me aceita apenas texto. Insira o link da imagem/PDF (Google Drive público, Dropbox) direto no texto da mensagem. O médico clica e vê o material instantaneamente.</div>' +
    '<div class="tip"><b>📅 1 material por semana</b>Com 6 materiais, você tem 6 semanas de cadência. Envie 1 por semana por médico para manter presença sem saturar.</div>' +
    '<div class="tip"><b>📌 Salvar como app no iPhone</b>Abra no Safari → Compartilhar (□↑) → "Adicionar à Tela de Início". Funciona como app, sem barra do browser, abre offline.</div>' +
    '<div class="tip"><b>☁️ Sincronização em equipe</b>Para múltiplos usuários, o próximo passo é conectar a um Google Sheets via Apps Script — cada envio registra automaticamente na planilha.</div>' +
    '<div class="tip"><b>💬 Mini-CRM</b>Adicionar um campo "Resposta do médico" por envio (Interessado / Neutro / Sem retorno) transforma o app em um rastreador de relacionamento.</div>';
}

// ─── INIT ─────────────────────────────────────────────────────────────────────
renderDocs();
</script>
</body>
</html>
