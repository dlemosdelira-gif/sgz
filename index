    <div id="insContent"></div>
  </div>
</div>

<!-- MODAL MÉDICO -->
<div class="overlay" id="docOverlay">
  <div class="modal">
    <h2 id="docModalTitle">Médico <button onclick="closeDocModal()">×</button></h2>
    <div class="field"><label>Nome</label><input id="iName" autocomplete="off" autocorrect="off" autocapitalize="words" spellcheck="false"></div>
    <div class="field-2col">
      <div class="field"><label>CRM</label><input id="iCrm" autocomplete="off" spellcheck="false"></div>
      <div class="field"><label>Potencial</label>
        <select id="iPot"><option value="A">A – Alta</option><option value="B">B – Média</option><option value="C" selected>C – Monitor.</option></select>
      </div>
    </div>
    <div class="field"><label>WhatsApp (ex: 19-99999-9999)</label><input id="iPhone" type="tel"></div>
    <div class="field-2col">
      <div class="field"><label>Cidade</label><input id="iCity" autocomplete="off" autocorrect="off" spellcheck="false"></div>
      <div class="field"><label>Especialidade</label>
        <select id="iEsp"><option value="Hematologia (BR)">Hematologia</option><option value="Farmacia (BR)">Farmácia</option></select>
      </div>
    </div>
    <div class="field"><label>Conta / Instituição</label><input id="iConta" autocomplete="off" spellcheck="false"></div>
    <div class="btn-row">
      <button class="btn-cancel" onclick="closeDocModal()">Cancelar</button>
      <button class="btn-save" onclick="saveDoc()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL MATERIAL -->
<div class="overlay" id="matOverlay">
  <div class="modal">
    <h2 id="matModalTitle">Material <button onclick="closeMatModal()">×</button></h2>
    <div class="field"><label>Nome do material</label><input id="mName"></div>
    <div class="field"><label>Mensagem WhatsApp</label><textarea id="mMsg" placeholder="Olá! ..."></textarea></div>
    <div class="btn-row">
      <button class="btn-cancel" onclick="closeMatModal()">Cancelar</button>
      <button class="btn-save" onclick="saveMat()">Salvar</button>
    </div>
  </div>
</div>

<!-- MODAL CONFIRMAR DELETE -->
<div class="overlay" id="delOverlay">
  <div class="modal">
    <h2>Excluir <button onclick="closeDelModal()">×</button></h2>
    <p id="delMsg" style="font-size:14px;color:#333;margin-bottom:20px;line-height:1.5;"></p>
    <div class="btn-row">
      <button class="btn-cancel" onclick="closeDelModal()">Cancelar</button>
      <button class="btn-del-conf" onclick="confirmDel()">Excluir</button>
    </div>
  </div>
</div>

